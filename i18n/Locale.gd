	],
	"grade.wrong_seal_cmr": [
		"[color=#e74c3c]• Wrong Seal on CMR:[/color] The seal number on the CMR (%s) does not match the actual seal (%s). The CMR seal must match the physical seal — a mismatch means the receiving store cannot verify shipment integrity.",
