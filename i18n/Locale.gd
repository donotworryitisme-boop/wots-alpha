	# ==========================================================================
	# GRADING FEEDBACK — debrief strings from GradingEngine
	# Format: %s placeholders for dynamic values (counts, codes, names)
	# ==========================================================================
	"grade.tutorial_rework": [
		"[color=#f1c40f]• Tutorial rework:[/color] 1 deliberate rework was forgiven for learning purposes. In a real shift, this would cost ~1.1 minutes and 5 points.",
		"", "", "", "", "", "", "",
	],
	"grade.seq_priority": [
		"[color=#e74c3c]• Sequence:[/color] %s pallet(s) loaded out of priority sequence. In Priority Loading, the order is: Service Center deepest, then all D/D- pallets by type (Bikes → Bulky → Mecha), then all D+ pallets by type (Bikes → Bulky → Mecha), then C&C at the doors.\n\nD and D- pallets must go on this truck — no question. They go in first so they are guaranteed a spot. D+ is tomorrow's stock and goes after. If a pallet arrives late via phone call, load it where it fits — no need to rework what is already on the truck.",
		"", "", "", "", "", "", "",
	],
	"grade.seq_minor": [
		"[color=#e74c3c]• Sequence:[/color] %s pallet(s) loaded out of the standard sequence. The truck unloads from the doors inward — last in, first out. Every pallet in the wrong position means the store team has to move it aside to reach what they need. That's extra handling time at the store that delays their opening routine.",
		"", "", "", "", "", "", "",
	],
	"grade.seq_major": [
		"[color=#e74c3c]• Sequence:[/color] %s pallet(s) loaded out of the standard sequence. The truck unloads from the doors inward — last in, first out. The store team works in a fixed order: C&C off first for waiting customers, then Mecha for shelf restocking, then Bulky and Bikes for specialist teams, and Service Center last.\n\nEvery pallet in the wrong position has to be moved aside to reach what they need. At %s sequence errors, the store team could spend 30-60 minutes rearranging pallets on the dock floor — people who should be helping customers on the shop floor.",
		"", "", "", "", "", "", "",
	],
	"grade.co_interleave": [
		"[color=#e74c3c]• Co-Loading Sequence:[/color] %s Store 1 pallet(s) loaded after Store 2 pallets had started. Store 1 goes deepest because it is unloaded second — the truck visits Store 2 first. A Store 1 pallet among Store 2's section means the driver at Store 2 encounters pallets that do not belong to them. They have to move them aside, unload their own, then push the Store 1 pallets back. This adds 10-15 minutes at Store 2 and risks Store 1 pallets being damaged or left behind at the wrong location.",
		"", "", "", "", "", "", "",
	],
	"grade.rework_smart": [
		"[color=#2ecc71]• Smart rework:[/color] %s pallet(s) removed to make room for late-arriving D- pallets. No penalty — this was the right call. The D- pallets were overdue and the store needed them. Unloading D+ to make room shows you understood the priority and acted on it.",
		"", "", "", "", "", "", "",
	],
	"grade.rework_minor": [
		"[color=#e74c3c]• Rework:[/color] %s pallet(s) pulled back off the truck. Each rework costs 5 points and adds ~1.1 minutes to your shift clock.",
		"", "", "", "", "", "", "",
	],
	"grade.rework_major": [
		"[color=#e74c3c]• Rework:[/color] %s pallet(s) removed and reloaded during the shift. Occasional rework is normal — a wave arrives and you need to make space. But %s reworks in a single loading suggests pallets were loaded without checking the full picture first. Each one adds ~1.1 minutes, pushing closer to the departure window. If the driver is waiting, that's time the store receives their delivery late.",
		"", "", "", "", "", "", "",
	],
	"grade.as400_co_missing": [
		"[color=#e74c3c]• AS400 Validation:[/color] RAQ not confirmed for %s. Each store needs its own F10 confirmation. Without it, the receiving team has no digital record of what is on the truck — they have to manually check every pallet against the paper CMR. Any discrepancy becomes harder to trace because there is no system record of what was supposed to be there.",
		"", "", "", "", "", "", "",
	],
	"grade.as400_missing": [
		"[color=#e74c3c]• AS400 Validation:[/color] The truck was sealed without pressing F10 to confirm the RAQ. The AS400 is the digital twin of the physical truck — it is how the store knows what is coming before the truck arrives. Without validation, the receiving team has to manually check every pallet against the paper CMR. If there is a discrepancy — a missing pallet, a wrong delivery — there is no digital trail to trace it. The store loses 15-20 minutes of receiving time, and any missing item becomes an investigation with no starting point.",
		"", "", "", "", "", "", "",
	],
	"grade.cc_left_behind": [
		"[color=#e74c3c][b]• CRITICAL — C&C Left Behind:[/b][/color] %s Click & Collect pallet(s) left on the dock. These are customer orders — someone placed an order online, chose store pickup, and received a confirmation with a pickup date. They may have driven 30 minutes to the store. When they arrive at the counter, the store team searches the system, sees the pallet was assigned to your truck, and has to tell the customer it did not arrive. The customer either waits for the next truck — which may not be until tomorrow — or cancels. One forgotten C&C pallet can cost a customer relationship that took years to build.",
		"", "", "", "", "", "", "",
	],
	"grade.cc_not_investigated": [
		"[color=#e74c3c][b]• CRITICAL — C&C Not Investigated:[/b][/color] %s C&C pallet(s) were listed in the RAQ but not on the dock — and departments were never contacted. The pallets were somewhere in the warehouse: possibly still being picked, stuck on a conveyor, or placed at the wrong dock. A single phone call to the C&C department would have located them in time. Without that call, the truck sealed without them, and the store has no way to know they were supposed to be there until a customer arrives to collect an order that is not in the building. The RAQ existed specifically to catch this — checking it before loading, noticing the gap, and calling is the procedure that prevents this.",
		"", "", "", "", "", "", "",
	],
	"grade.priority_left_behind": [
		"[color=#e74c3c]• Priority Pallets Left Behind:[/color] %s pallet(s) with a D or D- delivery date left on the dock. D and D- pallets must be on this truck — D means due today, D- means already overdue. D+ (tomorrow's stock) is secondary and can be left behind if needed.\n\nLeaving D/D- on the dock while D+ was loaded means the store misses deliveries that were already expected. The information was visible in the RAQ delivery dates.",
		"", "", "", "", "", "", "",
	],
	"grade.transit_not_checked": [
		"[color=#f1c40f]• Transit Rack Not Checked:[/color] Items were waiting on the transit rack — collis or UATs that belong to this shipment but were not placed on the dock with the rest. They were listed in the RAQ as TRANSIT rows. The truck sealed without them, so the store receives an incomplete delivery. Those items stay in Tilburg until someone notices and adds them to the next available truck — which may not go to the same store for another day.",
		"", "", "", "", "", "", "",
	],
	"grade.adr_not_collected": [
		"[color=#e74c3c][b]• CRITICAL — ADR Not Collected:[/b][/color] The ADR pallet was listed in the RAQ from the start — a red row signaling dangerous goods under the Accord Dangereux Routier (lithium batteries, aerosols, or other regulated items). It was in the yellow lockers, locked separately because ADR goods require controlled handling. Sealing the truck without it means regulated goods remain unsecured in the warehouse without an active shipment record. This is not an efficiency issue — it is a compliance requirement. If an incident occurs with unsecured ADR material, the warehouse is liable. The store also expected the ADR goods and may have customer orders depending on them.",
		"", "", "", "", "", "", "",
	],
	"grade.adr_left_on_dock": [
		"[color=#e74c3c]• ADR Left on Dock:[/color] The ADR goods were collected from the yellow lockers and placed on a dock pallet, but that pallet was never loaded onto the truck. The dangerous goods declaration is now attached to a shipment that does not physically contain the goods. The store's ADR inventory will not match the transport documents.",
		"", "", "", "", "", "", "",
	],
	"grade.paperwork_both_missing": [
		"[color=#f1c40f]• Paperwork Not Reviewed:[/color] Neither the Loading Sheet nor the CMR was opened during this shift. The Loading Sheet tracks pallet counts by type and container. The CMR is the legal transport document signed by you and the driver. Both must be checked before the truck leaves — the driver will not accept a shipment without a completed CMR, and any count discrepancy found at the store traces back to the loader who signed it.",
		"", "", "", "", "", "", "",
	],
	"grade.cmr_not_reviewed": [
		"[color=#f1c40f]• CMR Not Reviewed:[/color] The CMR panel was never opened. The CMR is the legal contract between sender, carrier, and receiver. Without reviewing it, weight, volume, and pallet counts may not match the physical load. The driver checks the CMR at the gate — discrepancies delay departure.",
		"", "", "", "", "", "", "",
	],
	"grade.cmr2_not_opened": [
		"[color=#e74c3c]• CMR for Store 2 Not Completed:[/color] This is a co-loading shift with two destinations but the second CMR was never opened. Each store needs its own CMR — the driver delivers to Store 1 first, hands over that CMR, then continues to Store 2 with the second CMR. Without a second CMR, the driver has no legal transport document for the second delivery.",
		"", "", "", "", "", "", "",
	],
	"grade.ls_not_reviewed": [
		"[color=#f1c40f]• Loading Sheet Not Reviewed:[/color] The Loading Sheet was never opened. It tracks EUR, Plastic, and Magnum pallet counts live during loading. These numbers feed directly into the CMR. Without checking the sheet, the CMR counts rely on memory rather than a running tally.",
		"", "", "", "", "", "", "",
	],
	"grade.wrong_store_code": [
		"[color=#e74c3c]• Wrong Store Code:[/color] The store code on the Loading Sheet (%s) does not match the actual destination (%s). The store code links the physical shipment to the digital AS400 record. A wrong code means the AS400 shows the truck going to one store while the paperwork says another — the driver may deliver to the wrong location, or the receiving store rejects the shipment because the documents do not match their system.",
		"", "", "", "", "", "", "",
	],
	"grade.wrong_seal_ls": [
		"[color=#e74c3c]• Wrong Seal Number:[/color] The seal number on the Loading Sheet (%s) does not match the actual seal (%s). The seal number proves the truck was not opened between loading and delivery. If the number on paper does not match the physical seal, the receiving store must treat the shipment as potentially tampered — this triggers an incident report and a full inventory count at the dock.",
		"", "", "", "", "", "", "",
	],
	"grade.wrong_dock_ls": [
		"[color=#f1c40f]• Wrong Dock Number:[/color] The dock number on the Loading Sheet (%s) does not match dock %s. This is a minor error — the dock number helps trace which physical location was used if there is a discrepancy later. Wrong dock on paper means any investigation starts at the wrong bay.",
		"", "", "", "", "", "", "",
	],
	"grade.wrong_expedition_ls": [
		"[color=#e74c3c]• Wrong Expedition on Loading Sheet:[/color] The expedition number on the Loading Sheet (%s) does not match the AS400 expedition (%s). The expedition number is the unique identifier that ties the physical truck to the digital shipment record. A mismatch means the Loading Sheet and AS400 describe different shipments.",
		"", "", "", "", "", "", "",
	],
	"grade.wrong_expedition_cmr": [
		"[color=#e74c3c]• Wrong Expedition on CMR:[/color] The expedition number on the CMR (%s) does not match the AS400 expedition (%s). The CMR is a legal transport contract — the expedition number must match the digital record exactly. A mismatch can void the CMR's legal standing if a cargo dispute arises.",
		"", "", "", "", "", "", "",
	],
	"grade.wrong_weight_cmr": [
		"[color=#e74c3c]• Wrong Weight on CMR:[/color] The weight on the CMR (%s kg) differs from the actual loaded weight (%s kg) by more than 5%%. The CMR weight determines transport pricing and legal liability limits. An inaccurate weight can result in overcharge, underinsurance, or a failed weight check at the border.",
		"", "", "", "", "", "", "",
	],
	"grade.wrong_volume_cmr": [
		"[color=#e74c3c]• Wrong Volume on CMR:[/color] The volume on the CMR (%s dm³) differs from the actual loaded volume (%s dm³) by more than 5%%. Volume determines whether the carrier's trailer capacity was correctly utilised and affects freight cost calculations.",
		"", "", "", "", "", "", "",
	],
	"grade.wrong_uat_ls": [
		"[color=#f1c40f]• UAT Count Wrong:[/color] You wrote %s UATs on the Loading Sheet but %s were loaded. The store uses this number to verify the delivery is complete.",
		"", "", "", "", "", "", "",
	],
	"grade.wrong_collis_ls": [
		"[color=#f1c40f]• Collis Count Wrong:[/color] You wrote %s collis on the Loading Sheet but %s were loaded. Collis counts feed into the store's inventory reconciliation.",
		"", "", "", "", "", "", "",
	],
	"grade.wrong_eur_ls": [
		"[color=#f1c40f]• EUR Pallet Count Wrong:[/color] You wrote %s EUR pallets but %s were loaded. Pallet counts by base type determine emballage returns — the store sends back what they received.",
		"", "", "", "", "", "", "",
	],
	"grade.wrong_plastic_ls": [
		"[color=#f1c40f]• Plastic Pallet Count Wrong:[/color] You wrote %s plastic pallets but %s were loaded.",
		"", "", "", "", "", "", "",
	],
	"grade.wrong_magnum_ls": [
		"[color=#f1c40f]• Magnum Count Wrong:[/color] You wrote %s magnums but %s were loaded.",
		"", "", "", "", "", "", "",
	],
	"grade.wrong_uat_cmr": [
		"[color=#f1c40f]• CMR UAT Count Wrong:[/color] You wrote %s UATs on the CMR but %s were loaded. The CMR is a legal document — the receiving store checks counts against it.",
		"", "", "", "", "", "", "",
	],
	"grade.wrong_collis_cmr": [
		"[color=#f1c40f]• CMR Collis Count Wrong:[/color] You wrote %s collis on the CMR but %s were loaded.",
		"", "", "", "", "", "", "",
	],
	"grade.wrong_eur_cmr": [
