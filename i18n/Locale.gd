class_name Locale
extends RefCounted
## Internationalization for WOTS Bay B2B training layer.
## AS400 screens, Office, RAQ, store names stay in original language.
## Tutorial, SOPs, buttons, debrief, portal UI get translated.

enum Lang { EN, NL, FR, PT, ES, IT, HR, PL }

static var current_lang: int = Lang.EN

static var LANG_NAMES: Array[String] = [
	"English", "Nederlands", "Français", "Português",
	"Español", "Italiano", "Hrvatski", "Polski"
]

## ISO 639-1 codes matching the Lang enum order.
static var _LANG_CODES: Array[String] = [
	"en", "nl", "fr", "pt", "es", "it", "hr", "pl"
]


static func lang_name(lang: int) -> String:
	if lang >= 0 and lang < LANG_NAMES.size():
		return LANG_NAMES[lang]
	return LANG_NAMES[0]


static func t(key: String) -> String:
	if not _ui.has(key):
		return key
	var arr: Array = _ui[key]
	var idx: int = current_lang
	if idx >= 0 and idx < arr.size():
		var val: String = str(arr[idx])
		if val != "":
			return val
	return str(arr[0])


static func get_sop_database() -> Array:
	## Returns SOP articles for current language.
	## Falls back to English if no translation exists for a given article.
	## Adds _en_title field to preserve English title for tab categorization.
	var result: Array = _sop_en.duplicate(true)
	for i: int in range(result.size()):
		result[i]["_en_title"] = str(result[i].get("title", ""))
	if current_lang == Lang.EN:
		return result
	var lang_key: String = _LANG_CODES[current_lang]
	for i: int in range(result.size()):
		var title: String = result[i].get("_en_title", "")
		if _sop_i18n.has(title) and _sop_i18n[title].has(lang_key):
			var tr_data: Dictionary = _sop_i18n[title][lang_key]
			if tr_data.has("title") and str(tr_data["title"]) != "":
				result[i]["title"] = str(tr_data["title"])
			if tr_data.has("content") and str(tr_data["content"]) != "":
				result[i]["content"] = str(tr_data["content"])
			if tr_data.has("tags"):
				result[i]["tags"] = tr_data["tags"]
	return result


